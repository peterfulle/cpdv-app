# ── Database ─────────────────────────────────────────────────────────
# En local puedes usar SQLite cambiando provider en prisma/schema.prisma
# En producción (Render) Postgres lo inyecta el render.yaml automáticamente
DATABASE_URL=postgresql://user:password@host:5432/dbname?schema=public

# ── NextAuth ─────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-strong-random-string
# En producción usa la URL pública del servicio (https://...onrender.com)
NEXTAUTH_URL=http://localhost:3000

# ── Uploads ──────────────────────────────────────────────────────────
# Carpeta donde se guardan comprobantes. En Render se monta un Disk aquí.
UPLOAD_DIR=public/comprobantes

# ── MercadoPago ──────────────────────────────────────────────────────
# Credenciales de tu app MP — NUNCA commitear los valores reales
MP_PUBLIC_KEY=
MP_ACCESS_TOKEN=
MP_CLIENT_ID=
MP_CLIENT_SECRET=
# URL pública para webhooks (en local usar ngrok, en prod la URL de Render)
MP_WEBHOOK_BASE_URL=http://localhost:3000
